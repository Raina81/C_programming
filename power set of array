#include <stdio.h>
int main()
{
    int a[]={2,3,1,8};
    int i,j,k,l;
    printf("power set of array a:\n");
    for(i=0;i<=1;i++)
    {
        for (j=0;j<=1;j++)
        {
            for(k=0;k<=1;k++)
            {
                for(l=0;l<=1;l++)
                {
                    printf("{");
                if (i==1)
                   printf("%d",a[0]);
                   
                if(j==1)
                   printf("%d",a[1]);
                   
                if(k==1)
                   printf("%d",a[2]);
                   
                if(l==1)
                printf("%d",a[3]);
                printf("}\n");
                }    
                
            }
        }
        
    }
    return 0;
}
