#include <stdio.h>
int gcd(int a,int b){
    int g=1;
    for(int i=1;i<=a && i<=b;i++){
        if(a%i==0 && b%i==0){
            g=i;
        }
    }
    return g;
}
int main(){
    int x,y;
    printf("enter two numbers");
    scanf("%d%d",&x,&y);
    printf("gcd of %d and %d is %d\n", x,y,gcd(x,y));
    return 0;
}
